{
    "name": "rcsofttech/php-image-guard",
    "description": "SSIM-based image quality verification with auto-retry compression loop for PHP 8.4+",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ssim",
        "image",
        "quality",
        "compression",
        "verification",
        "php"
    ],
    "authors": [
        {
            "name": "Rahul Chavan",
            "email": "rcsofttechsolution@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-gd": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "lint:md": "npx -y markdownlint-cli2 \"**/*.md\" \"#vendor\""
    },
    "suggest": {
        "ext-imagick": "For higher-accuracy SSIM calculations via Imagick pixel export"
    },
    "autoload": {
        "psr-4": {
            "RcSoftTech\\ImageGuard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RcSoftTech\\ImageGuard\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}